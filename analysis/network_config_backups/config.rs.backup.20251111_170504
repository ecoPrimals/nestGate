impl TracingConfig {
    /// Create a new tracing configuration
    pub fn new() -> Self {
        Self::default()
    }

    /// Create a development configuration
    #[must_use]
    pub fn development() -> Self {
        Self {
            level: "debug".to_string(),
            console_enabled: true,
            file_enabled: true,
            json_format: false,
            distributed_tracing: false,
            performance: PerformanceConfig {
                async_logging: false,
                sampling_enabled: false,
                ..Default::default()
            },
            security: SecurityConfig {
                encryption_enabled: false,
                signing_enabled: false,
                pii_filtering_enabled: false,
                ..Default::default()
            },
            ..Default::default()
        }
    }

    /// Create a production configuration
    #[must_use]
    pub fn production() -> Self {
        Self {
            level: "info".to_string(),
            console_enabled: false,
            file_enabled: true,
            json_format: true,
            distributed_tracing: true,
            performance: PerformanceConfig {
                async_logging: true,
                sampling_enabled: true,
                sampling_rate: 0.1,
                ..Default::default()
            },
            security: SecurityConfig {
                encryption_enabled: true,
                signing_enabled: true,
                pii_filtering_enabled: true,
                ..Default::default()
            },
            ..Default::default()
        }
    }

    /// Validate configuration
    ///
    /// # Errors
    ///
    /// This function will return an error if:
    /// - The operation fails due to invalid input
    /// - System resources are unavailable
    /// - Network or I/O errors occur
        pub fn validate(&self) -> Result<(), String>  {
        // Validate log level
        if !["trace", "debug", "info", "warn", "error"].contains(&self.level.as_str()) {
            return Err(format!("Invalid log level: {self.level}"));
        }

        // Validate file path if file logging is enabled
        if self.file_enabled && self.file_path.is_none() {
            return Err("File path must be specified when file logging is enabled".to_string());
        }

        // Validate Jaeger endpoint if distributed tracing is enabled
        if self.distributed_tracing && self.jaeger_endpoint.is_none() {
            return Err(
                "Jaeger endpoint must be specified when distributed tracing is enabled".to_string(),
            );
        }

        // Validate performance configuration
        if self.performance.worker_threads == 0 {
            return Err("Worker threads must be greater than 0".to_string());
        }

        if self.performance.queue_size == 0 {
            return Err("Queue size must be greater than 0".to_string());
        }

        if self.performance.sampling_rate < 0.0 || self.performance.sampling_rate > 1.0 {
            return Err("Sampling rate must be between 0.0 and 1.0".to_string());
        }

        Ok(())
    }
}


