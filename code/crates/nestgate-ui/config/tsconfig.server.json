{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "outDir": "../../../dist/crates/nestgate-ui/server",
    "rootDir": "../",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "sourceMap": true,
    "baseUrl": "../",
    "paths": {
      "*": ["*", "node_modules/*"]
    }
  },
  "include": [
    "../server/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "**/*.test.ts",
    "../src/**/*.ts"
  ]
} 