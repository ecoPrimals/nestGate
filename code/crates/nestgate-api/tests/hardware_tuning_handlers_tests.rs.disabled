}

#[tokio::test]
async fn test_system_profile_tier_classification() {
    let profile = get_system_profile().await.unwrap().0;

    let valid_tiers = vec!["high", "medium", "low"];
    assert!(
        valid_tiers.contains(&profile.system_tier.as_str()),
        "System tier should be one of: high, medium, low"
    );
}

// **TUNING SESSION TESTS**

#[tokio::test]
async fn test_start_tuning_session_success() {
    let response = start_tuning_session().await;
    assert!(response.is_ok());

    let session = response.unwrap().0;
    assert!(!session.session_id.is_empty());
    assert!(!session.status.is_empty());
}

#[tokio::test]
async fn test_tuning_session_has_id() {
    let session = start_tuning_session().await.unwrap().0;

    assert!(
        !session.session_id.is_empty(),
        "Session ID should not be empty"
    );
    assert!(
        session.session_id.len() > 10,
        "Session ID should be meaningful"
    );
}

#[tokio::test]
async fn test_tuning_session_status_valid() {
    let session = start_tuning_session().await.unwrap().0;

    let valid_statuses = vec!["active", "pending", "running", "initialized"];
    assert!(
        valid_statuses.contains(&session.status.as_str()),
        "Session status should be valid"
    );
}

#[tokio::test]
async fn test_tuning_session_recommendations_present() {
    let session = start_tuning_session().await.unwrap().0;

    assert!(
        session.recommendations.len() > 0,
        "Session should have at least one recommendation"
    );
}

#[tokio::test]
async fn test_multiple_tuning_sessions() {
    let session1 = start_tuning_session().await.unwrap().0;
    let session2 = start_tuning_session().await.unwrap().0;

    // Each session should have a unique ID
    assert_ne!(
        session1.session_id, session2.session_id,
        "Each session should have a unique ID"
    );
}

// **EDGE CASE TESTS**

#[tokio::test]
async fn test_concurrent_benchmark_requests() {
    let mut handles = vec![];

    for _ in 0..5 {
        handles.push(tokio::spawn(async { run_hardware_benchmarks().await }));
    }

    for handle in handles {
        let result = handle.await.unwrap();
        assert!(result.is_ok(), "Concurrent benchmarks should succeed");
    }
}

#[tokio::test]
async fn test_concurrent_metrics_requests() {
    let mut handles = vec![];

    for _ in 0..10 {
        handles.push(tokio::spawn(async { get_live_metrics().await }));
    }

    for handle in handles {
        let result = handle.await.unwrap();
        assert!(result.is_ok(), "Concurrent metrics requests should succeed");
    }
}

#[tokio::test]
async fn test_rapid_allocation_deallocation() {
    for _ in 0..5 {
        let request = ComputeResourceRequest {
            cpu_cores: 2,
            memory_gb: 4,
            gpu_count: 0,
        };

        let response = allocate_compute_resources(axum::Json(request)).await;
        assert!(response.is_ok());
    }
}

// **INTEGRATION TESTS**

#[tokio::test]
async fn test_full_hardware_tuning_workflow() {
    // 1. Get capabilities
    let caps = get_system_capabilities().await.unwrap().0;
    assert!(caps.max_cpu_cores > 0);

    // 2. Run benchmarks
    let benchmarks = run_hardware_benchmarks().await.unwrap().0;
    assert!(benchmarks.len() > 0);

    // 3. Get profile
    let profile = get_system_profile().await.unwrap().0;
    assert!(profile.total_cores > 0);

    // 4. Start tuning session
    let session = start_tuning_session().await.unwrap().0;
    assert!(!session.session_id.is_empty());

    // 5. Get live metrics
    let metrics = get_live_metrics().await.unwrap().0;
    assert!(metrics.cpu_usage >= 0.0);
}

#[tokio::test]
async fn test_allocation_respects_system_limits() {
    let caps = get_system_capabilities().await.unwrap().0;

    // Try to allocate exactly what's available
    let request = ComputeResourceRequest {
        cpu_cores: caps.cpu_cores as u32,
        memory_gb: caps.memory_gb as u32,
        gpu_count: 0,
    };

    let response = allocate_compute_resources(axum::Json(request)).await;
    // Should succeed or fail gracefully based on current system state
    assert!(response.is_ok() || response.is_err());
}
