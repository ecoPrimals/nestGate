// ==================== BOXED ERROR DETAILS STRUCTS ====================

/// Network error details - boxed to reduce enum size
#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct NetworkErrorDetails {
    /// Error message
    pub message: String,
    /// Network operation that failed
    pub operation: String,
    /// Remote address if applicable
    pub address: Option<String>,
    /// Remote address (alias for compatibility)
    pub remote_address: Option<String>,
    /// Network endpoint
    pub endpoint: Option<String>,
    /// Retry after duration in seconds
    pub retry_after: Option<u64>,
    /// Network-specific error code
    pub network_code: Option<String>,
    /// Whether the operation is retryable
    pub retryable: bool,
    /// Whether the error is recoverable (alias for retryable)
    pub recoverable: bool,
    /// Network-specific error data - BOXED for performance
    pub network_data: Option<Box<NetworkErrorData>>,
    /// Error context - BOXED for performance
    pub context: Option<Box<ErrorContext>>,
}

/// Validation error details - boxed to reduce enum size
#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct ValidationErrorDetails {
    /// Error message
    pub message: String,
    /// Field or data that failed validation
    pub field: String,
    /// Current invalid value
    pub value: Option<String>,
    /// Current invalid value (alias for compatibility)
    pub current_value: Option<String>,
    /// Expected format or constraint
    pub constraint: Option<String>,
    /// Expected value (alias for compatibility)
    pub expected: Option<String>,
    /// Error context - BOXED for performance
    pub context: Option<Box<ErrorContext>>,
}

impl ValidationErrorDetails {
    /// Create a new validation error details
    pub fn new(
        message: String,
        field: String,
        value: Option<String>,
        current_value: Option<String>,
        constraint: Option<String>,
        expected: Option<String>,
        context: Option<Box<ErrorContext>>,
    ) -> Self { Self {
            message,
            field,
            value,
            current_value,
            constraint,
            expected,
            context,
         }

    /// Create a simple validation error
    pub fn simple(message: String, field: String) -> Self { Self {
            message,
            field,
            value: None,
            current_value: None,
            constraint: None,
            expected: None,
            context: None,
         }
}

