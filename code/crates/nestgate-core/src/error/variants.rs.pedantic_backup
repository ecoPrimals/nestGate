// ==================== CANONICAL MODERNIZATION HELPERS ====================

impl NestGateUnifiedError {
    /// Create API error with boxed context
    pub fn api_with_context(message: String, context: ErrorContext) -> Self { Self::Api {
            message,
            status_code: None,
            request_id: None,
            endpoint: None,
            context: Some(Box::new(context)),
         }

    /// Create storage error with boxed data
    pub fn storage_with_data(
        message: String,
        operation: String,
        storage_data: StorageErrorData,
    ) -> Self { Self::Storage {
            message,
            operation,
            resource: None,
            retryable: false,
            storage_data: Some(Box::new(storage_data)),
            context: None,
         }

    /// Create network error with boxed data
    pub fn network_with_data(
        message: String,
        operation: String,
        network_data: NetworkErrorData,
    ) -> Self {
        Self::Network(Box::new(NetworkErrorDetails {
            message,
            operation,
            address: None,
            remote_address: None,
            endpoint: None,
            retry_after: None,
            network_code: None,
            retryable: false,
            recoverable: false,
            network_data: Some(Box::new(network_data)),
            context: None,
        }))
    }

    /// Get error context if available
    pub fn context(&self) -> Option<&str> {
        match self {
            Self::Api { context, .. } => context.as_deref(),
            Self::Storage { context, .. } => context.as_deref(),
            Self::Network(details) => Some(&details.context),
            _ => None,
        }
    }

    /// Check if error is retryable
    pub fn is_retryable(&self) -> bool {
        match self {
            Self::Storage { retryable, .. } => *retryable,
            Self::Network(details) => details.retryable,
            Self::Security { retryable, .. } => *retryable,
            _ => false,
        }
    }
}

// ==================== CANONICAL ERROR CONSTRUCTORS ====================

/// Canonical error construction helpers for consistent error creation
impl NestGateUnifiedError {
    /// Create a simple configuration error
    pub fn config_error(field: &str, message: &str) -> Self { Self::Configuration {
            field: field.to_string(),
            message: message.to_string(),
            current_value: None,
            expected: None,
            user_error: true,
         }

    /// Create a simple API error
    pub fn api_error(message: &str) -> Self { Self::Api {
            message: message.to_string(),
            status_code: None,
            request_id: None,
            endpoint: None,
            context: None,
         }

    /// Create a simple storage error
    pub fn storage_error(message: &str, operation: &str) -> Self { Self::Storage {
            message: message.to_string(),
            operation: operation.to_string(),
            resource: None,
            retryable: false,
            storage_data: None,
            context: None,
         }

    /// Create a simple network error
    pub fn network_error(message: &str, operation: &str) -> Self {
        Self::Network(Box::new(NetworkErrorDetails {
            message: message.to_string(),
            operation: operation.to_string(),
            address: None,
            remote_address: None,
            endpoint: None,
            retry_after: None,
            network_code: None,
            retryable: false,
            recoverable: false,
            network_data: None,
            context: None,
        }))
    }

    /// Create a simple internal error
    pub fn internal_error(message: &str, component: &str) -> Self { Self::Internal {
            message: message.to_string(),
            component: component.to_string(),
            context: None,
         }

    /// Create an internal error with debug context
    pub fn internal_error_with_debug_context(
        message: &str,
        component: &str,
        location: &str,
    ) -> Self { Self::Internal {
            message: message.to_string(),
            component: component.to_string(),
            context: Some(Box::new(crate::error::context::ErrorContext {
                error_id: uuid::Uuid::new_v4().to_string(),
                stack_trace: None,
                related_errors: vec![],
                operation: "internal_error".to_string(),
                component: component.to_string(),
                metadata: {
                    let mut map = std::collections::HashMap::new();
                    map.insert("location".to_string(), location.to_string());
                    map
                },
                timestamp: std::time::SystemTime::now(),
                retry_info: None,
                recovery_suggestions: vec![],
                performance_metrics: None,
                environment: None })),
        }
    }

    /// Create a timeout error
    pub fn timeout_error(operation: &str, duration_ms: u64) -> Self {
        Self::Timeout {
            message: format!(
                "Operation '{operation}' timed out after {duration_ms}ms"
            ),
            operation: operation.to_string(),
            timeout: Duration::from_millis(duration_ms),
            context: None,
        }
    }

    /// Create an invalid input error
    pub fn invalid_input(message: String) -> Self {
        Self::Validation(Box::new(ValidationErrorDetails {
            field: "input".to_string(),
            message,
            value: None,
            current_value: None,
            constraint: None,
            expected: None,
            context: None,
        }))
    }

    /// Create an invalid input error with field
    pub fn invalid_input_with_field(field: &str, message: String) -> Self {
        Self::Validation(Box::new(ValidationErrorDetails {
            field: field.to_string(),
            message,
            value: None,
            current_value: None,
            constraint: None,
            expected: None,
            context: None,
        }))
    }

    /// Create a configuration error
    pub fn configuration_error(message: String) -> Self { Self::Configuration {
            field: "general".to_string(),
            message,
            current_value: None,
            expected: None,
            user_error: true,
         }

    /// Create a configuration error with field details
    pub fn configuration_error_with_field(
        field: &str,
        message: String,
        current: Option<String>,
        expected: Option<String>,
    ) -> Self { Self::Configuration {
            field: field.to_string(),
            message,
            current_value: current,
            expected,
            user_error: true,
         }

    /// Create a permission denied error with operation
    pub fn permission_denied_with_operation(operation: &str, resource: &str) -> Self {
        Self::Security {
            message: format!(
                "Permission denied for operation '{operation}' on resource '{resource}'"
            ),
            operation: operation.to_string(),
            subject: None,
            retryable: false,
            security_data: None,
            context: None,
        }
    }

    /// PEDANTIC: Create validation error with full context
    pub fn validation_error(
        message: String,
        field: String,
        current_value: Option<String>,
        value: Option<String>,
        constraint: Option<String>,
        expected: Option<String>,
    ) -> Self {
        Self::Validation(Box::new(ValidationErrorDetails {
            field,
            message,
            current_value,
            value,
            constraint,
            expected,
            context: None,
        }))
    }

    /// PEDANTIC: Create simple validation error with minimal context
    pub fn simple_validation_error(message: String, field: String) -> Self {
        Self::Validation(Box::new(ValidationErrorDetails {
            field,
            message,
            current_value: None,
            value: None,
            constraint: None,
            expected: None,
            context: None,
        }))
    }
}

