    #[test]
    fn test_volume_request_validation() {
        let request = mcp_integration::McpVolumeRequest {
            volume_id: "test_volume".to_string(),
            tier: CoreStorageTier::Warm,
            size_gb: 5,
        };
        
        assert_eq!(request.volume_id, "test_volume");
