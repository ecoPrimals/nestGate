//! ZFS Integration Tests for NestGate
//! 
//! Tests the actual ZFS functionality with real types and proper error handling

use std::time::{Duration, SystemTime};
use tempfile::TempDir;

use nestgate_core::StorageTier as CoreStorageTier;
use nestgate_zfs::{
    config::ZfsConfig,
    manager::{ZfsManager, EnhancedServiceStatus, HealthState},
};

/// Test environment for ZFS integration tests
struct ZfsTestEnvironment {
    temp_dir: TempDir,
    config: ZfsConfig,
    zfs_manager: Option<ZfsManager>,
}

impl ZfsTestEnvironment {
    async fn new() -> Result<Self, Box<dyn std::error::Error>> {
        let temp_dir = TempDir::new()?;
        
        let config = ZfsConfig {
            default_pool: "test_pool".to_string(),
            enable_ai_integration: Some(false), // Disable AI for tests
            automation: None, // Disable automation for tests
            ..Default::default()
        };
        
        Ok(Self {
            temp_dir,
            config,
            zfs_manager: None,
        })
    }
    
    async fn initialize_manager(&mut self) -> Result<(), Box<dyn std::error::Error>> {
        // Try to create ZFS manager, but handle gracefully if ZFS is not available
        match ZfsManager::new(self.config.clone()).await {
            Ok(manager) => {
                self.zfs_manager = Some(manager);
                Ok(())
            }
            Err(e) => {
                println!("ZFS not available, using mock mode: {}", e);
                Ok(())
            }
        }
    }
    
    fn get_manager(&self) -> Option<&ZfsManager> {
        self.zfs_manager.as_ref()
    }
}

impl Drop for ZfsTestEnvironment {
    fn drop(&mut self) {
        // Clean up any resources
        if let Some(_manager) = self.zfs_manager.take() {
            // Manager cleanup happens automatically
        }
    }
}

