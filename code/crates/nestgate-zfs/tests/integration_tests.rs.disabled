// ============================================================================
// PHASE 6: ADVANCED INTEGRATION TESTING FOR PHASES 1-5
// ============================================================================

#[cfg(test)]
mod comprehensive_algorithm_integration_tests {
    use super::*;
    use std::collections::HashMap;
    use std::time::{SystemTime, Duration};
    use tokio::time::sleep;
    use serial_test::serial;
    
    #[tokio::test]
    #[serial]
    async fn test_end_to_end_tier_assignment_pipeline() -> Result<(), Box<dyn std::error::Error>> {
        // Initialize test environment
        let mut env = ZfsTestEnvironment::new().await?;
        env.initialize_manager().await?;
        
        if let Some(manager) = env.get_manager() {
            println!("🧪 Testing end-to-end tier assignment pipeline...");
            
            // Phase 1: Test tier assignment algorithm with various file types
            let test_cases = vec![
                ("/test/database.db", 1024 * 1024 * 1024, "Database file should prefer hot tier"),
                ("/test/video.mp4", 10 * 1024 * 1024 * 1024, "Large media should prefer cold tier"),
                ("/test/document.pdf", 5 * 1024 * 1024, "Small document should prefer warm tier"),
                ("/test/archive.tar.gz", 50 * 1024 * 1024 * 1024, "Archive should prefer cold tier"),
            ];
            
            for (path, size, description) in test_cases {
                println!("  📁 Testing: {}", description);
                
                // Test tier evaluation
                let tier_result = manager.evaluate_tier_for_dataset(path, size).await;
                assert!(tier_result.is_ok(), "Tier evaluation should succeed for {}", path);
                
                let tier_info = tier_result.unwrap();
                assert!(tier_info.confidence > 0.0, "Should have confidence > 0 for {}", path);
                assert!(!tier_info.reasoning.is_empty(), "Should provide reasoning for {}", path);
                
                println!("    ✅ Assigned tier: {:?} (confidence: {:.2})", tier_info.recommended_tier, tier_info.confidence);
            }
        }
        
        Ok(())
    }
    
    #[tokio::test]
    #[serial]
    async fn test_lifecycle_management_comprehensive() -> Result<(), Box<dyn std::error::Error>> {
        let mut env = ZfsTestEnvironment::new().await?;
        env.initialize_manager().await?;
        
        if let Some(manager) = env.get_manager() {
            println!("🔄 Testing comprehensive lifecycle management...");
            
            // Test dataset creation with lifecycle tracking
            let test_datasets = vec![
                ("new-dataset", nestgate_core::StorageTier::Hot),
                ("aging-dataset", nestgate_core::StorageTier::Warm),
                ("archive-dataset", nestgate_core::StorageTier::Cold),
            ];
            
            for (dataset_name, initial_tier) in test_datasets {
                println!("  📊 Testing lifecycle for dataset: {}", dataset_name);
                
                // Create dataset with lifecycle tracking
                let dataset_result = manager.create_dataset(dataset_name, "testpool", initial_tier).await;
                assert!(dataset_result.is_ok(), "Dataset creation should succeed");
                
                let dataset_info = dataset_result.unwrap();
                assert_eq!(dataset_info.name, dataset_name);
                assert_eq!(dataset_info.tier, initial_tier);
                
                // Test lifecycle rules application
                let lifecycle_result = manager.apply_lifecycle_rules(dataset_name).await;
                assert!(lifecycle_result.is_ok(), "Lifecycle rules should apply successfully");
                
                let lifecycle_info = lifecycle_result.unwrap();
                assert!(lifecycle_info.rules_applied >= 0, "Should apply 0 or more rules");
                
                println!("    ✅ Applied {} lifecycle rules", lifecycle_info.rules_applied);
            }
        }
        
        Ok(())
    }
    
    #[tokio::test]
    #[serial]
    async fn test_ai_tier_prediction_integration() -> Result<(), Box<dyn std::error::Error>> {
        let mut env = ZfsTestEnvironment::new().await?;
        env.initialize_manager().await?;
        
        if let Some(manager) = env.get_manager() {
            if let Some(ai_integration) = &manager.ai_integration {
                println!("🤖 Testing AI tier prediction integration...");
                
                // Test feature engineering with real file analysis
                let test_files = vec![
                    ("database.db", 2 * 1024 * 1024 * 1024), // 2GB database
                    ("video.mkv", 50 * 1024 * 1024 * 1024), // 50GB video
                    ("config.json", 4 * 1024), // 4KB config file
                ];
                
                for (filename, size) in test_files {
                    println!("  🎯 Predicting tier for: {} ({} bytes)", filename, size);
                    
                    let prediction_result = ai_integration.predict_optimal_tier(filename, size).await;
                    
                    match prediction_result {
                        Ok(prediction) => {
                            assert!(prediction.confidence >= 0.0 && prediction.confidence <= 1.0, 
                                   "Confidence should be normalized");
                            assert!(!prediction.reasoning.is_empty(), "Should provide reasoning");
                            println!("    ✅ Predicted: {:?} (confidence: {:.2})", 
                                   prediction.predicted_tier, prediction.confidence);
                        }
                        Err(e) => {
                            println!("    ⚠️ AI prediction fallback (expected in test env): {}", e);
                        }
                    }
                }
            } else {
                println!("⚠️ AI integration disabled in test environment");
            }
        }
        
        Ok(())
    }
    
    #[tokio::test]
    #[serial]
    async fn test_optimization_opportunity_detection() -> Result<(), Box<dyn std::error::Error>> {
        let mut env = ZfsTestEnvironment::new().await?;
        env.initialize_manager().await?;
        
        if let Some(manager) = env.get_manager() {
            if let Some(ai_integration) = &manager.ai_integration {
                println!("🔍 Testing optimization opportunity detection...");
                
                // Test comprehensive optimization analysis
                let opportunities_result = ai_integration.detect_optimization_opportunities().await;
                
                match opportunities_result {
                    Ok(opportunities) => {
                        println!("  📈 Found {} optimization opportunities", opportunities.len());
                        
                        for (i, opportunity) in opportunities.iter().take(5).enumerate() {
                            assert!(!opportunity.id.is_empty(), "Opportunity should have ID");
                            assert!(!opportunity.description.is_empty(), "Should have description");
                            assert!(opportunity.confidence_score >= 0.0 && opportunity.confidence_score <= 1.0,
                                   "Confidence should be normalized");
                            
                            println!("    {}. {} (confidence: {:.2})", 
                                   i + 1, opportunity.description, opportunity.confidence_score);
                        }
                        
                        // Test opportunity prioritization
                        let mut sorted_opportunities = opportunities.clone();
                        sorted_opportunities.sort_by(|a, b| {
                            b.confidence_score.partial_cmp(&a.confidence_score).unwrap_or(std::cmp::Ordering::Equal)
                        });
                        
                        if !sorted_opportunities.is_empty() {
                            let highest_confidence = sorted_opportunities[0].confidence_score;
                            let lowest_confidence = sorted_opportunities.last().unwrap().confidence_score;
                            assert!(highest_confidence >= lowest_confidence, 
                                   "Opportunities should be sortable by confidence");
                        }
                    }
                    Err(e) => {
                        println!("  ⚠️ Optimization detection handled gracefully: {}", e);
                    }
                }
            }
        }
        
        Ok(())
    }
    
    #[tokio::test]
    #[serial]
    async fn test_performance_engine_real_time_monitoring() -> Result<(), Box<dyn std::error::Error>> {
        use nestgate_zfs::performance_engine::*;
        
        println!("⚡ Testing real-time performance monitoring...");
        
        // Create performance engine with real system integration
        let config = nestgate_zfs::ZfsConfig::default();
        let pool_manager = std::sync::Arc::new(nestgate_zfs::ZfsPoolManager::new(&config).await?);
        let dataset_manager = std::sync::Arc::new(nestgate_zfs::ZfsDatasetManager::new(config.clone(), pool_manager.clone()));
        
        let engine = PerformanceOptimizationEngine::new(
            config,
            pool_manager.clone(),
            dataset_manager.clone(),
        );
        
        // Test real system metrics collection
        println!("  💾 Testing system memory collection...");
        let memory_result = engine.get_system_memory_usage().await;
        assert!(memory_result.is_ok(), "Should collect system memory");
        
        let memory_usage = memory_result.unwrap();
        assert!(memory_usage.total_memory > 0, "Total memory should be positive");
        assert!(memory_usage.total_memory >= memory_usage.used_memory, 
               "Total memory should be >= used memory");
        
        println!("    ✅ Memory: {:.2}GB total, {:.2}GB used", 
               memory_usage.total_memory as f64 / (1024.0 * 1024.0 * 1024.0),
               memory_usage.used_memory as f64 / (1024.0 * 1024.0 * 1024.0));
        
        // Test ZFS ARC statistics if available
        println!("  🧠 Testing ARC statistics collection...");
        let arc_result = engine.get_arc_statistics().await;
        
        match arc_result {
            Ok(arc_stats) => {
                assert!(arc_stats.hit_ratio >= 0.0 && arc_stats.hit_ratio <= 1.0, 
                       "ARC hit ratio should be normalized");
                assert!(arc_stats.size_bytes > 0, "ARC size should be positive");
                
                println!("    ✅ ARC: {:.1}% hit ratio, {:.2}GB size", 
                       arc_stats.hit_ratio * 100.0,
                       arc_stats.size_bytes as f64 / (1024.0 * 1024.0 * 1024.0));
            }
            Err(e) => {
                println!("    ⚠️ ARC stats not available (expected without ZFS): {}", e);
            }
        }
        
        // Test trend calculation algorithms
        println!("  📊 Testing trend calculation algorithms...");
        let test_values = vec![10.0, 12.0, 14.0, 16.0, 18.0]; // Increasing trend
        let trend = PerformanceOptimizationEngine::calculate_trend(&test_values);
        assert!(trend > 0.0, "Should detect positive trend");
        
        println!("    ✅ Trend analysis: {:.3} (positive trend detected)", trend);
        
        Ok(())
    }
    
    #[tokio::test]
    #[serial]
    async fn test_emergency_mitigation_simulation() -> Result<(), Box<dyn std::error::Error>> {
        use nestgate_zfs::performance_engine::*;
        
        println!("🚨 Testing emergency mitigation simulation...");
        
        let config = nestgate_zfs::ZfsConfig::default();
        let pool_manager = std::sync::Arc::new(nestgate_zfs::ZfsPoolManager::new(&config).await?);
        let dataset_manager = std::sync::Arc::new(nestgate_zfs::ZfsDatasetManager::new(config.clone(), pool_manager.clone()));
        
        let engine = PerformanceOptimizationEngine::new(
            config,
            pool_manager,
            dataset_manager,
        );
        
        // Test emergency mitigation scenarios
        let emergency_scenarios = vec![
            (AlertType::PerformanceBottleneck, "test-pool"),
            (AlertType::HighLatency, "test-dataset"),
            (AlertType::LowThroughput, "test-dataset"),
            (AlertType::CacheInefficiency, "system"),
            (AlertType::FragmentationHigh, "test-pool"),
        ];
        
        for (alert_type, component) in emergency_scenarios {
            println!("  🔧 Testing mitigation for: {:?}", alert_type);
            
            let alert = PerformanceAlert {
                alert_type: alert_type.clone(),
                severity: AlertSeverity::High,
                component: component.to_string(),
                description: format!("Simulated {:?} alert", alert_type),
                timestamp: SystemTime::now(),
            };
            
            let mitigation_result = engine.apply_immediate_zfs_mitigations(&alert).await;
            assert!(mitigation_result.is_ok(), "Mitigation should not fail");
            
            let actions = mitigation_result.unwrap();
            println!("    ✅ Applied {} mitigation actions", actions.len());
            
            for action in &actions {
                assert!(!action.is_empty(), "Action should have description");
                println!("      - {}", action);
            }
        }
        
        Ok(())
    }
    
    #[tokio::test]
    #[serial]
    async fn test_comprehensive_error_handling() -> Result<(), Box<dyn std::error::Error>> {
        println!("🔬 Testing comprehensive error handling...");
        
        let mut env = ZfsTestEnvironment::new().await?;
        env.initialize_manager().await?;
        
        if let Some(manager) = env.get_manager() {
            // Test invalid dataset operations
            println!("  ❌ Testing invalid operations...");
            
            let invalid_results = vec![
                manager.create_dataset("", "invalid-pool", nestgate_core::StorageTier::Hot).await,
                manager.migrate_dataset("nonexistent-dataset", nestgate_core::StorageTier::Cold).await,
                manager.delete_dataset("nonexistent-dataset").await,
            ];
            
            for (i, result) in invalid_results.iter().enumerate() {
                match result {
                    Ok(_) => println!("    ⚠️ Operation {} succeeded (unexpected)", i + 1),
                    Err(e) => println!("    ✅ Operation {} failed gracefully: {}", i + 1, e),
                }
            }
            
            // Test resource exhaustion scenarios
            println!("  💥 Testing resource exhaustion...");
            
            // Attempt to create many datasets rapidly
            let mut creation_tasks = Vec::new();
            for i in 0..10 {
                let dataset_name = format!("stress-test-{}", i);
                let manager_clone = manager.clone();
                
                creation_tasks.push(tokio::spawn(async move {
                    manager_clone.create_dataset(&dataset_name, "testpool", nestgate_core::StorageTier::Warm).await
                }));
            }
            
            let results = futures::future::join_all(creation_tasks).await;
            let successful = results.iter().filter(|r| r.is_ok() && r.as_ref().unwrap().is_ok()).count();
            let failed = results.len() - successful;
            
            println!("    📊 Stress test results: {} succeeded, {} failed", successful, failed);
            assert!(successful + failed == 10, "All operations should complete");
        }
        
        Ok(())
    }
    
    #[tokio::test]
    #[serial] 
    async fn test_performance_regression_prevention() -> Result<(), Box<dyn std::error::Error>> {
        println!("⏱️ Testing performance regression prevention...");
        
        let mut env = ZfsTestEnvironment::new().await?;
        env.initialize_manager().await?;
        
        if let Some(manager) = env.get_manager() {
            // Performance benchmarks for critical operations
            let operations = vec![
                ("tier_evaluation", || async {
                    manager.evaluate_tier_for_dataset("/test/file.txt", 1024 * 1024).await
                }),
                ("dataset_creation", || async {
                    manager.create_dataset("perf-test", "testpool", nestgate_core::StorageTier::Warm).await
                }),
                ("lifecycle_rules", || async {
                    manager.apply_lifecycle_rules("test-dataset").await
                }),
            ];
            
            for (operation_name, operation) in operations {
                let start_time = std::time::Instant::now();
                let _result = operation().await;
                let duration = start_time.elapsed();
                
                // Performance thresholds (adjust based on requirements)
                let max_duration = Duration::from_millis(100); // 100ms max
                
                if duration <= max_duration {
                    println!("    ✅ {} completed in {:?} (under threshold)", operation_name, duration);
                } else {
                    println!("    ⚠️ {} took {:?} (exceeds {:?} threshold)", operation_name, duration, max_duration);
                }
            }
        }
        
        Ok(())
    }
    
    #[tokio::test]
    #[serial]
    async fn test_autonomous_optimization_cycle() -> Result<(), Box<dyn std::error::Error>> {
        let mut env = ZfsTestEnvironment::new().await?;
        env.initialize_manager().await?;
        
        if let Some(manager) = env.get_manager() {
            if let Some(ai_integration) = &manager.ai_integration {
                println!("🤖 Testing autonomous optimization cycle...");
                
                // Run autonomous optimization cycle
                let cycle_result = ai_integration.run_autonomous_optimization_cycle().await;
                
                match cycle_result {
                    Ok(report) => {
                        println!("  📊 Optimization cycle completed:");
                        println!("    - Duration: {:.2}s", report.cycle_duration_seconds);
                        println!("    - Opportunities detected: {}", report.opportunities_detected);
                        println!("    - Optimizations applied: {}", report.optimizations_applied);
                        println!("    - Performance improvement: {:.1}%", report.total_performance_improvement);
                        println!("    - Skipped: {}", report.optimizations_skipped);
                        println!("    - Failed: {}", report.optimizations_failed);
                        
                        // Validate report structure
                        assert!(report.cycle_duration_seconds > 0.0, "Cycle should take measurable time");
                        assert!(report.opportunities_detected >= 0, "Should detect 0+ opportunities");
                        assert!(report.total_performance_improvement >= 0.0, "Performance improvement should be non-negative");
                        
                        for recommendation in &report.recommendations {
                            assert!(!recommendation.is_empty(), "Recommendations should not be empty");
                            println!("    💡 {}", recommendation);
                        }
                        
                        println!("    ✅ Autonomous optimization cycle successful");
                    }
                    Err(e) => {
                        println!("  ⚠️ Optimization cycle handled gracefully: {}", e);
                    }
                }
            }
        }
        
        Ok(())
    }
}

// Helper structures for comprehensive testing
#[derive(Debug, Clone)]
struct MockPerformanceAlert {
    alert_type: String,
    severity: String,
    component: String,
    description: String,
}

#[derive(Debug, Clone)]
struct TestScenario {
    name: String,
    setup: fn() -> Result<(), Box<dyn std::error::Error>>,
    test: fn() -> Result<(), Box<dyn std::error::Error>>,
    cleanup: fn() -> Result<(), Box<dyn std::error::Error>>,
}

// Mock data generators for testing
fn generate_test_file_analysis(path: &str, size: u64) -> nestgate_automation::types::prediction::FileAnalysis {
    nestgate_automation::types::prediction::FileAnalysis {
        path: path.to_string(),
        size_bytes: size,
        extension: path.split('.').last().unwrap_or("").to_string(),
        created: SystemTime::now() - Duration::from_secs(86400 * 30), // 30 days ago
        modified: SystemTime::now() - Duration::from_secs(86400 * 5), // 5 days ago
        accessed: SystemTime::now() - Duration::from_secs(86400), // 1 day ago
        access_count: 50,
    }
}

// Performance testing utilities
async fn measure_operation_performance<F, Fut, T>(operation: F) -> (T, Duration) 
where
    F: FnOnce() -> Fut,
    Fut: std::future::Future<Output = T>,
{
    let start = std::time::Instant::now();
    let result = operation().await;
    let duration = start.elapsed();
    (result, duration)
}

// Integration test utilities
async fn setup_test_datasets(manager: &nestgate_zfs::ZfsManager) -> Result<Vec<String>, Box<dyn std::error::Error>> {
    let datasets = vec![
        "test-hot-dataset",
        "test-warm-dataset", 
        "test-cold-dataset",
    ];
    
    let tiers = vec![
        nestgate_core::StorageTier::Hot,
        nestgate_core::StorageTier::Warm,
        nestgate_core::StorageTier::Cold,
    ];
    
    for (dataset, tier) in datasets.iter().zip(tiers.iter()) {
        match manager.create_dataset(dataset, "testpool", *tier).await {
            Ok(_) => println!("✅ Created test dataset: {}", dataset),
            Err(e) => println!("⚠️ Test dataset creation handled: {} - {}", dataset, e),
        }
    }
    
    Ok(datasets.iter().map(|s| s.to_string()).collect())
}

async fn cleanup_test_datasets(manager: &nestgate_zfs::ZfsManager, datasets: &[String]) -> Result<(), Box<dyn std::error::Error>> {
    for dataset in datasets {
        match manager.delete_dataset(dataset).await {
            Ok(_) => println!("🗑️ Cleaned up test dataset: {}", dataset),
            Err(e) => println!("⚠️ Test dataset cleanup handled: {} - {}", dataset, e),
        }
    }
    Ok(())
} 