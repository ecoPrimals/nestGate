#[cfg(test)]
mod dataset_properties_tests {
    use super::*;

    #[test]
    fn test_dataset_with_properties() {
        let mut properties = std::collections::HashMap::new();
        properties.insert("compression".to_string(), "lz4".to_string());
        properties.insert("atime".to_string(), "off".to_string());

        let dataset = DatasetInfo {
            name: "tank/props".to_string(),
            used_space: 0,
            available_space: 1024,
            file_count: None,
            compression_ratio: None,
            mount_point: "/mnt/props".to_string(),
            tier: StorageTier::Hot,
            properties: properties.clone(),
        };

        assert_eq!(dataset.properties.len(), 2);
        assert_eq!(
            dataset.properties.get("compression"),
            Some(&"lz4".to_string())
        );
        assert_eq!(dataset.properties.get("atime"), Some(&"off".to_string()));
    }

    #[test]
    fn test_dataset_empty_properties() {
        let dataset = DatasetInfo {
            name: "tank/empty".to_string(),
            used_space: 0,
            available_space: 1024,
            file_count: None,
            compression_ratio: None,
            mount_point: "/mnt/empty".to_string(),
            tier: StorageTier::Hot,
            properties: std::collections::HashMap::new(),
        };

        assert_eq!(dataset.properties.len(), 0);
        assert!(dataset.properties.is_empty());
    }

    #[test]
    fn test_dataset_property_access() {
        let mut properties = std::collections::HashMap::new();
        properties.insert("quota".to_string(), "100G".to_string());
        properties.insert("recordsize".to_string(), "128K".to_string());
        properties.insert("sync".to_string(), "standard".to_string());

        let dataset = DatasetInfo {
            name: "tank/access".to_string(),
            used_space: 0,
            available_space: 1024,
            file_count: None,
            compression_ratio: None,
            mount_point: "/mnt/access".to_string(),
            tier: StorageTier::Warm,
            properties,
        };

        assert!(dataset.properties.contains_key("quota"));
        assert!(dataset.properties.contains_key("recordsize"));
        assert!(dataset.properties.contains_key("sync"));
        assert!(!dataset.properties.contains_key("nonexistent"));
    }
}

#[cfg(test)]
mod dataset_space_tests {
    use super::*;

    #[test]
    fn test_dataset_space_zero() {
        let dataset = DatasetInfo {
            name: "tank/zero".to_string(),
            used_space: 0,
            available_space: 0,
            file_count: Some(0),
            compression_ratio: Some(1.0),
            mount_point: "/mnt/zero".to_string(),
            tier: StorageTier::Hot,
            properties: std::collections::HashMap::new(),
        };

        assert_eq!(dataset.used_space, 0);
        assert_eq!(dataset.available_space, 0);
        assert_eq!(dataset.file_count, Some(0));
    }

    #[test]
    fn test_dataset_space_large() {
        let used = 1024u64 * 1024 * 1024 * 500; // 500 GB
        let available = 1024u64 * 1024 * 1024 * 1000; // 1 TB

        let dataset = DatasetInfo {
            name: "tank/large".to_string(),
            used_space: used,
            available_space: available,
            file_count: Some(1_000_000),
            compression_ratio: Some(3.2),
            mount_point: "/mnt/large".to_string(),
            tier: StorageTier::Cold,
            properties: std::collections::HashMap::new(),
        };

        assert_eq!(dataset.used_space, used);
        assert_eq!(dataset.available_space, available);
        assert!(dataset.file_count.unwrap() > 999_999);
    }

    #[test]
    fn test_dataset_compression_ratios() {
        let ratios = vec![1.0, 1.5, 2.0, 2.5, 3.0, 5.0];

        for ratio in ratios {
            let dataset = DatasetInfo {
                name: format!("tank/ratio{}", ratio),
                used_space: 1024,
                available_space: 2048,
                file_count: None,
                compression_ratio: Some(ratio),
                mount_point: "/mnt/test".to_string(),
                tier: StorageTier::Hot,
                properties: std::collections::HashMap::new(),
            };

            assert_eq!(dataset.compression_ratio, Some(ratio));
            assert!(dataset.compression_ratio.unwrap() >= 1.0);
        }
    }
}

#[cfg(test)]
mod dataset_clone_tests {
    use super::*;

    #[test]
    fn test_dataset_info_clone() {
        let original = DatasetInfo {
            name: "tank/original".to_string(),
            used_space: 1024,
            available_space: 2048,
            file_count: Some(100),
            compression_ratio: Some(2.0),
            mount_point: "/mnt/original".to_string(),
            tier: StorageTier::Hot,
            properties: std::collections::HashMap::new(),
        };

        let cloned = original.clone();

        assert_eq!(original.name, cloned.name);
        assert_eq!(original.used_space, cloned.used_space);
        assert_eq!(original.available_space, cloned.available_space);
        assert_eq!(original.file_count, cloned.file_count);
        assert_eq!(original.compression_ratio, cloned.compression_ratio);
        assert_eq!(original.mount_point, cloned.mount_point);
    }

    #[test]
    fn test_dataset_debug_format() {
        let dataset = DatasetInfo {
            name: "tank/debug".to_string(),
            used_space: 1024,
            available_space: 2048,
            file_count: Some(50),
            compression_ratio: Some(1.5),
            mount_point: "/mnt/debug".to_string(),
            tier: StorageTier::Warm,
            properties: std::collections::HashMap::new(),
        };

        let debug_str = format!("{:?}", dataset);
        assert!(debug_str.contains("tank/debug"));
        assert!(debug_str.contains("DatasetInfo"));
    }
}

#[cfg(test)]
mod dataset_name_validation_tests {
    use super::*;

    #[test]
    fn test_dataset_simple_names() {
        let names = vec!["data", "backup", "storage", "archive"];

        for name in names {
            let dataset = DatasetInfo {
                name: format!("tank/{}", name),
                used_space: 0,
                available_space: 1024,
                file_count: None,
                compression_ratio: None,
                mount_point: format!("/mnt/{}", name),
                tier: StorageTier::Hot,
                properties: std::collections::HashMap::new(),
            };

            assert!(dataset.name.contains(name));
        }
    }

    #[test]
    fn test_dataset_hierarchical_names() {
        let paths = vec![
            "tank/data/users",
            "tank/backup/daily/2024",
            "storage/vm/images/production",
        ];

        for path in paths {
            let dataset = DatasetInfo {
                name: path.to_string(),
                used_space: 0,
                available_space: 1024,
                file_count: None,
                compression_ratio: None,
                mount_point: format!("/mnt/{}", path),
                tier: StorageTier::Warm,
                properties: std::collections::HashMap::new(),
            };

            assert!(dataset.name.contains('/'));
            assert_eq!(dataset.name, path);
        }
    }
}

#[cfg(test)]
mod dataset_mount_point_tests {
    use super::*;

    #[test]
    fn test_dataset_mount_points() {
        let mount_points = vec![
            "/mnt/data",
            "/mnt/tank/backup",
            "/storage/volumes/production",
        ];

        for mount_point in mount_points {
            let dataset = DatasetInfo {
                name: "tank/test".to_string(),
                used_space: 0,
                available_space: 1024,
                file_count: None,
                compression_ratio: None,
                mount_point: mount_point.to_string(),
                tier: StorageTier::Hot,
                properties: std::collections::HashMap::new(),
            };

            assert_eq!(dataset.mount_point, mount_point);
            assert!(dataset.mount_point.starts_with('/'));
        }
    }

    #[test]
    fn test_dataset_mount_point_formats() {
        // Test various mount point formats
        let formats = vec![
            ("/", "root"),
            ("/mnt", "standard"),
            ("/mnt/zfs/tank", "nested"),
            ("/storage/data/production", "deep"),
        ];

        for (mount_point, description) in formats {
            let dataset = DatasetInfo {
                name: format!("tank/{}", description),
                used_space: 0,
                available_space: 1024,
                file_count: None,
                compression_ratio: None,
                mount_point: mount_point.to_string(),
                tier: StorageTier::Hot,
                properties: std::collections::HashMap::new(),
            };

            assert_eq!(dataset.mount_point, mount_point);
        }
    }
}
