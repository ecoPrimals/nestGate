//! Tests for ZFS dataset management
//!
//! Comprehensive test suite for dataset operations including
//! creation, deletion, property management, and error handling.

use crate::config::ZfsConfig;
use crate::pool::ZfsPoolManager;
use nestgate_core::canonical_types::StorageTier;
use nestgate_zfs::dataset::*;
use std::sync::Arc;

#[cfg(test)]
mod dataset_creation_tests {
    use super::*;

    #[test]
    fn test_dataset_manager_construction() {
        let config = ZfsConfig::default();
        let pool_manager = Arc::new(ZfsPoolManager::new_for_testing());
        let manager = ZfsDatasetManager::new(config, pool_manager);

        // Manager should be created successfully
        assert!(format!("{:?}", manager).contains("ZfsDatasetManager"));
    }

    #[test]
    fn test_dataset_manager_with_shared_config() {
        let config = Arc::new(ZfsConfig::default());
        let pool_manager = Arc::new(ZfsPoolManager::new_for_testing());
        let manager = ZfsDatasetManager::with_shared_config(config.clone(), pool_manager);

        // Shared config should be used
        assert!(format!("{:?}", manager).contains("ZfsDatasetManager"));
    }

    #[test]
    fn test_dataset_manager_for_testing() {
        let manager = ZfsDatasetManager::new_for_testing();

        // Test manager should be created with defaults
        assert!(format!("{:?}", manager).contains("ZfsDatasetManager"));
    }

    #[test]
    fn test_dataset_info_creation() {
        let dataset = DatasetInfo {
            name: "tank/data".to_string(),
            used_space: 1024 * 1024 * 100,       // 100 MB
            available_space: 1024 * 1024 * 1024, // 1 GB
            file_count: Some(150),
            compression_ratio: Some(2.5),
            mount_point: "/mnt/tank/data".to_string(),
            tier: StorageTier::Hot,
            properties: std::collections::HashMap::new(),
        };

        assert_eq!(dataset.name, "tank/data");
        assert_eq!(dataset.used_space, 1024 * 1024 * 100);
        assert_eq!(dataset.available_space, 1024 * 1024 * 1024);
        assert_eq!(dataset.file_count, Some(150));
        assert_eq!(dataset.compression_ratio, Some(2.5));
        assert_eq!(dataset.mount_point, "/mnt/tank/data");
        assert!(matches!(dataset.tier, StorageTier::Hot));
    }

    #[test]
    fn test_dataset_info_serialization() {
        let dataset = DatasetInfo {
            name: "tank/data".to_string(),
            used_space: 1024,
            available_space: 2048,
            file_count: None,
            compression_ratio: None,
            mount_point: "/mnt/data".to_string(),
            tier: StorageTier::Warm,
            properties: std::collections::HashMap::new(),
        };

        // Should serialize to JSON
        let json = serde_json::to_string(&dataset);
        assert!(json.is_ok());

        // Should deserialize back
        let json_str = json.unwrap();
        let deserialized: Result<DatasetInfo, _> = serde_json::from_str(&json_str);
        assert!(deserialized.is_ok());
    }
}

