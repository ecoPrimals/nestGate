//! Modernization Coverage Boost Tests
//!
//! Systematic test additions to reach 90% coverage target.
//! Focus: Error paths, edge cases, integration scenarios.
//!
//! Session: December 5, 2025 - Modernization Sprint

use nestgate_core::zero_cost::providers::{
    ZeroCostFileStorage, ZeroCostJwtProvider, ZeroCostMemoryCache,
};
use nestgate_core::zero_cost::system::{ZeroCostSystem, ZeroCostSystemBuilder};
use nestgate_core::zero_cost::types::{RequestPriority, ZeroCostMetadata, ZeroCostRequest};

/// Test zero-cost system with various buffer sizes
#[test]
fn test_zero_cost_system_buffer_sizes() {
    // Small buffer
    let cache = ZeroCostMemoryCache::<8>::new();
    let security = ZeroCostJwtProvider::new([1u8; 32]);
    let storage = ZeroCostFileStorage::new("/tmp".to_string());
    let system = ZeroCostSystem::<_, _, _, 8, 1000>::new(cache, security, storage);
    assert_eq!(system.max_size(), 8);

    // Medium buffer
    let cache = ZeroCostMemoryCache::<256>::new();
    let security = ZeroCostJwtProvider::new([2u8; 32]);
    let storage = ZeroCostFileStorage::new("/tmp".to_string());
    let system = ZeroCostSystem::<_, _, _, 256, 5000>::new(cache, security, storage);
    assert_eq!(system.max_size(), 256);

    // Large buffer
    let cache = ZeroCostMemoryCache::<4096>::new();
    let security = ZeroCostJwtProvider::new([3u8; 32]);
    let storage = ZeroCostFileStorage::new("/tmp".to_string());
    let system = ZeroCostSystem::<_, _, _, 4096, 10000>::new(cache, security, storage);
    assert_eq!(system.max_size(), 4096);
}

/// Test zero-cost system with various timeout configurations
#[test]
fn test_zero_cost_system_timeouts() {
    let cache = ZeroCostMemoryCache::<16>::new();
    let security = ZeroCostJwtProvider::new([0u8; 32]);
    let storage = ZeroCostFileStorage::new("/tmp".to_string());

    // Short timeout
    let system =
        ZeroCostSystem::<_, _, _, 16, 100>::new(cache.clone(), security.clone(), storage.clone());
    assert_eq!(system.timeout_ms(), 100);

    // Medium timeout
    let system =
        ZeroCostSystem::<_, _, _, 16, 5000>::new(cache.clone(), security.clone(), storage.clone());
    assert_eq!(system.timeout_ms(), 5000);

    // Long timeout
    let system = ZeroCostSystem::<_, _, _, 16, 30000>::new(cache, security, storage);
    assert_eq!(system.timeout_ms(), 30000);
}

/// Test zero-cost system builder with different configurations
#[test]
fn test_zero_cost_system_builder() {
    // Small system
    let system = ZeroCostSystemBuilder::<64, 1000>::new().with_memory_cache();
    assert_eq!(system.max_size(), 64);
    assert_eq!(system.timeout_ms(), 1000);

    // Medium system
    let system = ZeroCostSystemBuilder::<512, 5000>::new().with_memory_cache();
    assert_eq!(system.max_size(), 512);
    assert_eq!(system.timeout_ms(), 5000);

    // Large system
    let system = ZeroCostSystemBuilder::<2048, 10000>::new().with_memory_cache();
    assert_eq!(system.max_size(), 2048);
    assert_eq!(system.timeout_ms(), 10000);
}

/// Test JWT provider with various secret keys
#[test]
fn test_jwt_provider_secret_variations() {
    // All zeros
    let provider = ZeroCostJwtProvider::new([0u8; 32]);
    assert_eq!(provider.secret(), &[0u8; 32]);
    assert!(!provider.verify_signature("test"));

    // All ones
    let provider = ZeroCostJwtProvider::new([1u8; 32]);
    assert_eq!(provider.secret(), &[1u8; 32]);
    assert!(provider.verify_signature("test"));

    // Pattern
    let mut key = [0u8; 32];
    for (i, byte) in key.iter_mut().enumerate() {
        *byte = (i % 256) as u8;
    }
    let provider = ZeroCostJwtProvider::new(key);
    assert_eq!(provider.secret(), &key);
}

/// Test file storage path validation edge cases
#[test]
fn test_file_storage_path_validation() {
    let storage = ZeroCostFileStorage::new("/var/lib/nestgate".to_string());
    assert_eq!(storage.base_path(), "/var/lib/nestgate");

    // Valid paths
    assert!(storage.is_path_valid("/var/lib/nestgate/data"));
    assert!(storage.is_path_valid("/var/lib/nestgate/config/app.toml"));
    assert!(storage.is_path_valid("/var/lib/nestgate"));

    // Invalid paths (outside base)
    assert!(!storage.is_path_valid("/var/lib/other"));
    assert!(!storage.is_path_valid("/tmp/data"));
    assert!(!storage.is_path_valid("/var/lib"));
}

/// Test memory cache capacity
#[test]
fn test_memory_cache_capacity() {
    let cache_small: ZeroCostMemoryCache<10> = ZeroCostMemoryCache::new();
    assert_eq!(cache_small.capacity(), 10);

    let cache_medium: ZeroCostMemoryCache<100> = ZeroCostMemoryCache::new();
    assert_eq!(cache_medium.capacity(), 100);

    let cache_large: ZeroCostMemoryCache<1000> = ZeroCostMemoryCache::new();
    assert_eq!(cache_large.capacity(), 1000);
}

/// Test zero-cost request with various priorities
#[test]
fn test_zero_cost_request_priorities() {
    // High priority
    let request = ZeroCostRequest {
        id: 1,
        data: vec![1, 2, 3],
        metadata: ZeroCostMetadata {
            timestamp: 1000,
            priority: RequestPriority::High,
            source: [0u8; 32],
        },
    };
    assert_eq!(request.id, 1);
    assert_eq!(request.metadata.priority, RequestPriority::High);

    // Normal priority
    let request = ZeroCostRequest {
        id: 2,
        data: vec![4, 5, 6],
        metadata: ZeroCostMetadata {
            timestamp: 2000,
            priority: RequestPriority::Normal,
            source: [1u8; 32],
        },
    };
    assert_eq!(request.metadata.priority, RequestPriority::Normal);

    // Low priority
    let request = ZeroCostRequest {
        id: 3,
        data: vec![7, 8, 9],
        metadata: ZeroCostMetadata {
            timestamp: 3000,
            priority: RequestPriority::Low,
            source: [2u8; 32],
        },
    };
    assert_eq!(request.metadata.priority, RequestPriority::Low);
}

/// Test system metrics tracking
#[test]
fn test_zero_cost_system_metrics() {
    let cache = ZeroCostMemoryCache::<32>::new();
    let security = ZeroCostJwtProvider::new([5u8; 32]);
    let storage = ZeroCostFileStorage::new("/tmp".to_string());
    let system = ZeroCostSystem::<_, _, _, 32, 5000>::new(cache, security, storage);

    let metrics = system.metrics();
    assert!(metrics.requests_processed > 0);
    assert!(metrics.average_latency_ns > 0);
}

/// Test provider references
#[test]
fn test_zero_cost_system_provider_access() {
    let cache = ZeroCostMemoryCache::<16>::new();
    let security = ZeroCostJwtProvider::new([7u8; 32]);
    let storage = ZeroCostFileStorage::new("/data".to_string());
    let system = ZeroCostSystem::<_, _, _, 16, 3000>::new(cache, security, storage);

    // Access providers
    assert_eq!(system.cache().capacity(), 16);
    assert_eq!(system.security().secret(), &[7u8; 32]);
    assert_eq!(system.storage().base_path(), "/data");
}

/// Test empty data handling
#[test]
fn test_zero_cost_request_empty_data() {
    let request = ZeroCostRequest {
        id: 999,
        data: vec![],
        metadata: ZeroCostMetadata {
            timestamp: 0,
            priority: RequestPriority::Normal,
            source: [0u8; 32],
        },
    };

    assert_eq!(request.id, 999);
    assert!(request.data.is_empty());
}

/// Test large data handling
#[test]
fn test_zero_cost_request_large_data() {
    let large_data = vec![0u8; 10000];
    let request = ZeroCostRequest {
        id: 1000,
        data: large_data.clone(),
        metadata: ZeroCostMetadata {
            timestamp: 5000,
            priority: RequestPriority::High,
            source: [255u8; 32],
        },
    };

    assert_eq!(request.id, 1000);
    assert_eq!(request.data.len(), 10000);
}
