# Test Environment Configuration
# These environment variables can be set to customize test behavior
# If not set, tests will use localhost defaults

# Primary test endpoint
NESTGATE_TEST_ENDPOINT=http://localhost:8080

# Alternative test endpoint  
NESTGATE_TEST_ENDPOINT_ALT=http://localhost:9999

# Test URL for network tests
NESTGATE_TEST_URL=http://localhost:8080

# Test hostname
NESTGATE_TEST_HOST=localhost
TEST_HOSTNAME=localhost

# Database test host
NESTGATE_TEST_DB_HOST=localhost

# General hostname for tests
NESTGATE_HOSTNAME=localhost 