# NestGate Production Environment Configuration
# This file demonstrates the successful externalization of hardcoded values
# Copy to .env or set these variables in your production environment

# ==================== NETWORK CONFIGURATION ====================
# API Server Configuration
NESTGATE_API_PORT=8080
NESTGATE_DEFAULT_PORT=8080
NESTGATE_BIND_ADDRESS=0.0.0.0
NESTGATE_LOCALHOST=127.0.0.1

# Connection Limits
NESTGATE_MAX_SERVICES=1000
NESTGATE_MAX_CONCURRENT_REQUESTS=10000
NESTGATE_SEND_BUFFER_SIZE=65536
NESTGATE_RECV_BUFFER_SIZE=65536

# WebSocket Configuration
NESTGATE_WEBSOCKET_PORT=8081
NESTGATE_WEBSOCKET_MAX_CONNECTIONS=1000
NESTGATE_WEBSOCKET_TIMEOUT=30
NESTGATE_WEBSOCKET_COMPRESSION=true
NESTGATE_WEBSOCKET_HEARTBEAT_INTERVAL=30

# ==================== TIMEOUT CONFIGURATION ====================
# Request and Connection Timeouts
NESTGATE_DEFAULT_TIMEOUT_SECS=30
NESTGATE_REQUEST_TIMEOUT_MS=30000
NESTGATE_CONNECTION_TIMEOUT_SECS=30

# Service Discovery Timeouts
NESTGATE_DISCOVERY_TIMEOUT_MS=5000
NESTGATE_HEALTH_CHECK_INTERVAL_SECS=30

# Retry Configuration
NESTGATE_DEFAULT_RETRY_ATTEMPTS=3

# ==================== ZFS BACKEND CONFIGURATION ====================
# ZFS Service Backend Type (native|remote)
NESTGATE_ZFS_BACKEND=native

# Remote ZFS Configuration (if using remote backend)
NESTGATE_ZFS_REMOTE_ENDPOINT=http://zfs-service:8080

# ==================== SERVICE DISCOVERY CONFIGURATION ====================
# Consul Service Discovery
CONSUL_HTTP_ADDR=http://consul:8500

# Kubernetes Service Discovery
KUBERNETES_SERVICE_HOST=kubernetes.default.svc
KUBERNETES_SERVICE_PORT=443

# ==================== CACHE CONFIGURATION ====================
# Cache Storage Directory
NESTGATE_CACHE_DIR=/var/cache/nestgate

# ==================== LOGGING AND MONITORING ====================
# Log Level (trace|debug|info|warn|error)
RUST_LOG=info

# Metrics Collection
NESTGATE_METRICS_ENABLED=true
NESTGATE_METRICS_PORT=9090

# ==================== PRODUCTION DEPLOYMENT ====================
# Environment Type
NESTGATE_ENVIRONMENT=production

# Instance Identification
NESTGATE_INSTANCE_ID=nestgate-prod-01
NESTGATE_CLUSTER_NAME=nestgate-production

# Security Configuration
NESTGATE_TLS_ENABLED=true
NESTGATE_TLS_CERT_PATH=/etc/ssl/certs/nestgate.pem
NESTGATE_TLS_KEY_PATH=/etc/ssl/private/nestgate.key

# Health Check Configuration
NESTGATE_HEALTH_CHECK_ENABLED=true
NESTGATE_HEALTH_CHECK_PORT=8082 