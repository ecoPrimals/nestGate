    #[test]
    fn test_security_config_default() {
        let config = SecurityConfig::default();
        assert_eq!(config.auth_method, AUTH_JWT);
        assert_eq!(config.encryption_algorithm, ENCRYPTION_AES_256_GCM);
        assert_eq!(config.key_rotation_days, 30);
        assert_eq!(config.max_failed_attempts, 5);
        assert!(config.rbac.enabled);
        assert_eq!(config.rbac.default_role, ROLE_USER);
    fn test_rbac_permissions() {
        let rbac = RbacConfig::default();
        // Test admin permissions
        assert!(rbac.has_permission(ROLE_ADMIN, PERM_READ));
        assert!(rbac.has_permission(ROLE_ADMIN, PERM_WRITE));
        assert!(rbac.has_permission(ROLE_ADMIN, PERM_DELETE));
        assert!(rbac.has_permission(ROLE_ADMIN, PERM_ADMIN));
        // Test user permissions
        assert!(rbac.has_permission(ROLE_USER, PERM_READ));
        assert!(rbac.has_permission(ROLE_USER, PERM_WRITE));
        assert!(!rbac.has_permission(ROLE_USER, PERM_DELETE));
        assert!(!rbac.has_permission(ROLE_USER, PERM_ADMIN));
        // Test readonly permissions
        assert!(rbac.has_permission(ROLE_READONLY, PERM_READ));
        assert!(!rbac.has_permission(ROLE_READONLY, PERM_WRITE));
        assert!(!rbac.has_permission(ROLE_READONLY, PERM_DELETE));
    fn test_role_inheritance() {
        let mut rbac = RbacConfig::default();
        // Create a role that inherits from user
        let mut power_user = RoleDefinition::new(
            ROLE_POWER_USER.to_string(),
            DESC_POWER_USER.to_string(),
            vec![PERM_DELETE.to_string()],
        power_user.inherit_from(ROLE_USER.to_string());
        rbac.add_role(power_user);
        // Test inherited permissions
        assert!(rbac.has_permission(ROLE_POWER_USER, PERM_READ)); // inherited from user
        assert!(rbac.has_permission(ROLE_POWER_USER, PERM_WRITE)); // inherited from user
        assert!(rbac.has_permission(ROLE_POWER_USER, PERM_DELETE)); // direct permission
        assert!(!rbac.has_permission(ROLE_POWER_USER, PERM_ADMIN)); // not inherited
        // Test all permissions
        let all_perms = rbac.get_all_permissions(ROLE_POWER_USER);
        assert!(all_perms.contains(&PERM_READ.to_string()));
        assert!(all_perms.contains(&PERM_WRITE.to_string()));
        assert!(all_perms.contains(&PERM_DELETE.to_string()));
